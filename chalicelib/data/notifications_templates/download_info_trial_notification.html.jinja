{% extends 'templates/base.html.jinja' %}

{% block title %}
CFDIs con errores
{% endblock %}

{% block body %}
<table style="padding-top: 30px; padding-left: 30px; padding-right: 30px;" width="600" cellpadding="0" cellspacing="0">
    <tr>
        <td>
            <h2 style="line-height: normal; font-size: 18px; margin: 0;">¡Hola, {{ user }}!</h2>
        </td>
    </tr>
    <tr>
        <td>
            <p style="font-size: 16px; line-height: 24px; letter-spacing: 0;">Hemos descargado tu información desde los
                portales del SAT, ahora puedes consultar un resumen de la información obtenida hasta ahora. ¡Seguimos
                trabajando por mantener tu información al día!
            </p>
        </td>
    </tr>
    <tr>
        <td>
            <p style="font-size: 16px; margin-top: 0; line-height: 24px;">Descarga hasta el día {{send_date}}.
            </p>
        </td>
        </td>
    </tr>


    <tr>
        <td>
            <table style="border: 1px solid rgb(207, 216, 220); border-radius: 4px; width: 100%;">
                <tr>
                    <th colspan="3"
                        style="padding: 15px; font-size: 14px; line-height: 22px; font-weight: 700; text-align: left; border-bottom: 1px solid rgb(207, 216, 220)">
                        Ingresos Nominales
                    </th>
                </tr>
                <tr>
                    <td
                        style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; padding-left: 15px; width: 170px;">
                        Mes:
                    </td>
                    <td
                        style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; width: 170px; text-align: center;">
                        {{ data_cfdi["prev_month"]["date"]}}</td>
                    <td
                        style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; padding-right: 15px; width: 170px; text-align: right;">
                        {{ data_cfdi["current_month"]["date"]}}</td>
                </tr>
                {# Cancelados #}
                <tr>
                    <td
                        style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; padding-left: 15px; width: 170px;">
                        Cancelados:</td>
                    <td
                        style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; width: 170px; text-align: center;">
                        {{data_cfdi["prev_month"]["cancelados"]}}</td>
                    <td
                        style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; padding-right: 15px; width: 170px; text-align: right;">
                        {{data_cfdi["current_month"]["cancelados"]}}
                    </td>
                </tr>
        </td>
    </tr>
    {# Vigentes #}
    <tr>
        <td
            style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; padding-left: 15px; width: 170px;">
            Vigentes:</td>
        <td
            style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; width: 170px; text-align: center;">
            {{data_cfdi["prev_month"]["vigentes"]}}</td>
        <td
            style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; padding-right: 15px; width: 170px; text-align: right;">
            {{data_cfdi["current_month"]["vigentes"]}}</td>
    </tr>
    {# Ingresos nominales #}
    <tr>
        <td
            style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; padding-left: 15px; width: 170px;">
            Ingresos nominales:</td>
        <td
            style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; width: 170px; text-align: center;">
            ${{ "{:,.2f}".format(data_cfdi["prev_month"]["Ingresos nominales"]) }}</td>
        <td
            style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; padding-right: 15px; width: 170px; text-align: right;">
            ${{ "{:,.2f}".format(data_cfdi["current_month"]["Ingresos nominales"]) }}</td>
    </tr>
    {# Pendiente de pago #}
    <tr>
        <td
            style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; padding-left: 15px; width: 170px;">
            Descuentos:</td>
        <td
            style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; width: 170px; text-align: center;">
            ${{ "{:,.2f}".format(data_cfdi["prev_month"]["Descuentos"]) }}</td>
        <td
            style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; padding-right: 15px; width: 170px; text-align: right;">
            ${{ "{:,.2f}".format(data_cfdi["current_month"]["Descuentos"]) }}</td>
    </tr>
    {# Ingresos netos #}
    <tr>
        <td
            style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; padding-left: 15px; width: 170px;">
            Ingresos netos:
        </td>
        <td
            style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; width: 170px; text-align: center;">
            ${{ "{:,.2f}".format(data_cfdi["prev_month"]["Ingresos netos"]) }}</td>
        <td
            style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; padding-right: 15px; width: 170px; text-align: right;">
            ${{ "{:,.2f}".format(data_cfdi["current_month"]["Ingresos netos"]) }}</td>
    </tr>
</table>
</td>
</tr>
<tr>
    <td>
        <table style="border: 1px solid rgb(207, 216, 220); border-radius: 4px; width: 100%; margin-top: 30px;">
            <tr>
                <th colspan="3"
                    style="padding: 15px; font-size: 14px; line-height: 22px; font-weight: 700; text-align: left; border-bottom: 1px solid rgb(207, 216, 220)">
                    IVA base flujo
                </th>
            </tr>
            <tr>
                <td
                    style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; padding-left: 15px; width: 170px;">
                    Mes:
                </td>
                <td
                    style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; width: 170px; text-align: center;">
                    {{ data_iva["prev_month"]["date"]}}</td>
    </td>
    <td
        style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; padding-right: 15px; width: 170px; text-align: right;">
        {{ data_iva["current_month"]["date"]}}</td>
    </td>
</tr>
{# IVA trasladado #}
<tr>
    <td
        style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; padding-left: 15px; width: 170px;">
        IVA trasladado:</td>
    <td
        style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; width: 170px; text-align: center;">
        ${{ "{:,.2f}".format(data_iva["prev_month"]["IVA trasladado"]) }}</td>
    <td
        style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; padding-right: 15px; width: 170px; text-align: right;">
        ${{ "{:,.2f}".format(data_iva["current_month"]["IVA trasladado"]) }}</td>
</tr>
{# IVA acreditable #}
<tr>
    <td
        style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; padding-left: 15px; width: 170px;">
        IVA acreditable:</td>
    <td
        style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; width: 170px; text-align: center;">
        ${{ "{:,.2f}".format(data_iva["prev_month"]["IVA acreditable"]) }}</td>
    <td
        style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; padding-right: 15px; width: 170px; text-align: right;">
        ${{ "{:,.2f}".format(data_iva["current_month"]["IVA acreditable"]) }}</td>
</tr>
{# IVA a cargo #}
<tr>
    <td
        style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; padding-left: 15px; width: 170px;">
        IVA a cargo:</td>
    <td
        style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; width: 170px; text-align: center;">
        ${{ "{:,.2f}".format(data_iva["prev_month"]["IVA a cargo"]) }}</td>
    <td
        style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; padding-right: 15px; width: 170px; text-align: right;">
        ${{ "{:,.2f}".format(data_iva["current_month"]["IVA a cargo"]) }}</td>
</tr>
{# Retenciones IVA #}
<tr>
    <td
        style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; padding-left: 15px; width: 170px;">
        Retenciones IVA:
    </td>
    <td
        style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; width: 170px; text-align: center;">
        ${{ "{:,.2f}".format(data_iva["prev_month"]["Retenciones IVA"]) }}</td>
    <td
        style="font-size: 14px; line-height: 22px; padding-top: 5px; padding-bottom: 5px; padding-right: 15px; width: 170px; text-align: right;">
        ${{ "{:,.2f}".format(data_iva["current_month"]["Retenciones IVA"]) }}</td>
</tr>
</table>
</td>
</tr>

<tr>
    <td style="padding-top: 15px;">
        <p style="font-size: 16px; font-weight: 400; line-height: 24px;">
            Explora Siigo Fiscal para analizar tu operación, validar tus CFDIs y descubrir las herramientas que
            tenemos para una gestión fiscal más fácil, completa y confiable.
    </td>
</tr>
<tr>
    <td style="padding-top: 26px; text-align: center;">
        <a style="width: 271px; height: 100%; background-color: rgb(0, 157, 255); padding: 11px 15px 12px 15px; font-size: 18px; font-weight: 700; color: rgb(255,255,255); border-radius: 6px; cursor:pointer; text-decoration: none;"
            href={{ main_button_url }}>
            Ingresa a tu cuenta aquí.
        </a>
    </td>
</tr>
<tr>
    <td style="padding-top: 15px;">
        <p style="font-size: 16px; font-weight: 400; line-height: 24px;">
            ¡Comienza a explorar las funcionalidades de Siigo Fiscal!
    </td>
</tr>
<tr>
    <td>
        <a style="color: rgb(0, 157, 255); font-size: 16px; font-weight: 700; cursor:pointer; text-decoration: none;"
            href="https://siigocontadorportaldeclientes.aspel.com.mx/inicia-en-siigo-fiscal/">
            <span>•</span> Ver tutoriales
        </a>
    </td>
</tr>
<tr>
    <td style="padding-top: 15px;">
        <p style="font-size: 16px; font-weight: 400; line-height: 24px;">
            ¿Tienes dudas sobre Siigo Fiscal? ¡Contacta a tu distribuidor, aliado de negocio, o llámanos al +52 55
            1840 1065!</p>
    </td>
</tr>
<tr>
    <td style="padding-top: 15px; font-weight: 400; line-height: 22px; font-size: 14px;">
        Equipo Siigo Fiscal
    </td>
</tr>
</table>
{% endblock %}
